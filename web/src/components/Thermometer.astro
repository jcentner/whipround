---
import { formatUsd } from "../../lib/format";

interface Props {
  goalCents: number;
  /** Funding floor (one block incl. buffer); drawn as a labeled tick (D15). */
  floorCents: number;
}

const { goalCents, floorCents } = Astro.props;

// Position of the floor tick along the track, clamped inside the rounded pill.
const floorPct =
  goalCents > 0 ? Math.min(98, Math.max(2, (floorCents / goalCents) * 100)) : 0;
---

<section class="thermometer" aria-label="Campaign progress">
  <div class="thermo-amounts">
    <span id="thermo-pledged" class="thermo-pledged" data-goal={goalCents}>
      {formatUsd(0)}
    </span>
    <span class="thermo-goal">pledged of <span id="thermo-goal-amt">{formatUsd(goalCents)}</span> goal</span>
  </div>

  <div
    id="thermo-track"
    class="thermo-track"
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax={goalCents}
    aria-valuenow="0"
  >
    <div id="thermo-fill" class="thermo-fill" style="width: 0%"></div>
    <div
      id="thermo-tick-floor"
      class="thermo-tick thermo-tick-floor"
      style={`left: ${floorPct}%`}
      aria-hidden="true"
    >
    </div>
    <div class="thermo-tick thermo-tick-goal" aria-hidden="true"></div>
  </div>

  <div class="thermo-ticklabels" aria-hidden="true">
    <span
      id="thermo-ticklabel-floor"
      class="ticklabel ticklabel-floor"
      style={`left: ${floorPct}%`}
    >
      1 block
    </span>
    <span class="ticklabel ticklabel-goal">goal</span>
  </div>

  <p class="thermo-count">
    <span id="thermo-countwrap" hidden><span id="thermo-count">0</span> pledgers</span>
    <span id="thermo-first" class="thermo-first">Nobody has pledged yet. Someone has to be first.</span>
  </p>
</section>

<script>
  import { formatUsd } from "../../lib/format";
  import { marketCoverageHtml } from "../../lib/preview";

  const pledgedEl = document.getElementById("thermo-pledged");
  const fillEl = document.getElementById("thermo-fill");
  const trackEl = document.getElementById("thermo-track");
  const countEl = document.getElementById("thermo-count");
  const countWrapEl = document.getElementById("thermo-countwrap");
  const firstEl = document.getElementById("thermo-first");
  const priceEl = document.getElementById("mkt-price");
  const bannerEl = document.getElementById("pledged-banner");

  // Numbers the island re-sizes from the live goal while the campaign is in
  // preview (D14). At launch the API returns the frozen campaign.ts goal, so
  // these writes just restate the build-time values — a harmless no-op.
  const goalAmtEl = document.getElementById("thermo-goal-amt");
  const tickFloorEl = document.getElementById("thermo-tick-floor");
  const tickLabelFloorEl = document.getElementById("thermo-ticklabel-floor");
  const ledgerEl = document.getElementById("ledger-math");
  const ledgerImpliedEl = document.getElementById("ledger-implied");
  const ledgerFloorEl = document.getElementById("ledger-floor");
  const ledgerGoalEl = document.getElementById("ledger-goal");
  const noteFloorEl = document.getElementById("note-floor");
  const faqFloorEl = document.getElementById("faq-floor");
  const coverageEl = document.getElementById("mkt-coverage");

  function applyGoal(goalCents: number, floorCents: number): void {
    const usdGoal = formatUsd(goalCents);
    const usdFloor = formatUsd(floorCents);
    if (goalAmtEl) goalAmtEl.textContent = usdGoal;
    if (ledgerGoalEl) ledgerGoalEl.textContent = usdGoal;
    if (ledgerFloorEl) ledgerFloorEl.textContent = usdFloor;
    if (noteFloorEl) noteFloorEl.textContent = usdFloor;
    if (faqFloorEl) faqFloorEl.textContent = usdFloor;
    if (trackEl) trackEl.setAttribute("aria-valuemax", String(goalCents));

    // Implied block price = goal / (blocks × buffer), kept consistent with the
    // displayed goal rather than read straight off the (rounded) live price.
    if (ledgerImpliedEl && ledgerEl) {
      const denom =
        Number(ledgerEl.dataset.targetBlocks) * Number(ledgerEl.dataset.buffer);
      if (denom > 0) {
        ledgerImpliedEl.textContent = formatUsd(Math.round(goalCents / denom));
      }
    }

    // Floor tick + label position, clamped inside the rounded pill.
    if (goalCents > 0) {
      const floorPct = Math.min(98, Math.max(2, (floorCents / goalCents) * 100));
      if (tickFloorEl) tickFloorEl.style.left = `${floorPct}%`;
      if (tickLabelFloorEl) tickLabelFloorEl.style.left = `${floorPct}%`;
    }

    // The market line's second sentence is banded on the displayed goal; the
    // interpolated value is numeric only, so this innerHTML carries no user input.
    if (coverageEl) coverageEl.innerHTML = marketCoverageHtml(goalCents);
  }

  async function refresh(): Promise<void> {
    try {
      const res = await fetch("/api/progress", {
        headers: { accept: "application/json" },
      });
      if (!res.ok) return;
      const p = (await res.json()) as {
        pledgedCents: number;
        pledgerCount: number;
        goalCents: number;
        floorCents: number;
        fraction: number;
        topBidCents?: number | null;
      };
      if (pledgedEl) pledgedEl.textContent = formatUsd(p.pledgedCents);
      if (fillEl) fillEl.style.width = `${Math.round((p.fraction ?? 0) * 100)}%`;
      if (trackEl) trackEl.setAttribute("aria-valuenow", String(p.pledgedCents));
      if (countEl) countEl.textContent = String(p.pledgerCount);
      const hasPledges = p.pledgerCount > 0;
      if (countWrapEl) countWrapEl.hidden = !hasPledges;
      if (firstEl) firstEl.hidden = hasPledges;
      if (priceEl && typeof p.topBidCents === "number") {
        priceEl.textContent = formatUsd(p.topBidCents);
      }
      if (typeof p.goalCents === "number") {
        applyGoal(p.goalCents, p.floorCents ?? 0);
      }
    } catch {
      /* network blip — keep the last rendered state */
    }
  }

  // Reveal the thank-you note when a pledger returns from Stripe checkout.
  if (bannerEl && new URLSearchParams(location.search).get("pledged") === "1") {
    bannerEl.hidden = false;
  }

  void refresh();
  setInterval(() => void refresh(), 30_000);
</script>

<style>
  .thermometer {
    margin: 1.5rem 0;
  }

  .thermo-amounts {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .thermo-pledged {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent-2);
  }

  .thermo-goal {
    color: var(--muted);
  }

  .thermo-track {
    position: relative;
    height: 1.4rem;
    background: var(--border);
    border: 1px solid var(--muted);
    border-radius: 999px;
    overflow: hidden;
  }

  .thermo-fill {
    height: 100%;
    min-width: 0.7rem;
    background: var(--accent-2);
    border-radius: 999px;
    transition: width 0.6s ease;
  }

  .thermo-tick {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--accent);
    opacity: 0.8;
  }
  .thermo-tick-goal {
    right: 0.45rem;
  }
  .thermo-tick-floor {
    /* left set inline from floorPct */
    transform: translateX(-50%);
  }

  .thermo-ticklabels {
    position: relative;
    height: 1rem;
    margin-top: 0.3rem;
  }
  .ticklabel {
    position: absolute;
    top: 0;
    font-size: 0.7rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .ticklabel-floor {
    /* left set inline from floorPct */
    transform: translateX(-50%);
    color: var(--accent);
  }
  .ticklabel-goal {
    right: 0;
  }

  .thermo-count {
    margin: 0.5rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .thermo-first {
    color: var(--accent-2);
  }
</style>

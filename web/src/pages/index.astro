---
import Layout from "../layouts/Layout.astro";
import Thermometer from "../components/Thermometer.astro";
import SpinnerMock from "../components/SpinnerMock.astro";
import { campaign } from "../../lib/campaign";
import { formatUsd } from "../../lib/format";
import { goalBreakdown } from "../../lib/economics";
import { marketCoverageHtml } from "../../lib/preview";

const isPlaceholder = (s: string) => s.startsWith("[") && s.endsWith("]");
const pledgeReady = campaign.pledgeLinks.every((link) => !isPlaceholder(link.url));
const campaignChosen = !isPlaceholder(campaign.beneficiaryName);
const isPreview = isPlaceholder(campaign.fundingDeadline);

const breakdown = goalBreakdown(
  campaign.goalCents,
  campaign.targetBlocks,
  campaign.clickBufferMultiplier,
);

const deadlineText = isPlaceholder(campaign.fundingDeadline)
  ? "the deadline (set at launch)"
  : new Date(campaign.fundingDeadline).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });

function pledgeLabel(amountCents: number | "custom"): string {
  return amountCents === "custom" ? "Choose amount" : formatUsd(amountCents);
}

function pledgeClass(amountCents: number | "custom"): string {
  if (amountCents === "custom") return "pledge-btn ghost";
  if (amountCents === 1000) return "pledge-btn primary";
  return "pledge-btn secondary";
}
---

<Layout title={`Whipround — ${campaign.headline}`}>
  <main>
    <header class="brand">
      <div class="brand-row">
        <span class="wordmark">WHIPROUND<span class="cursor" aria-hidden="true">▌</span></span>
        <nav class="site-links" aria-label="Elsewhere">
          <a href="https://x.com/whiprounddev">@whiprounddev</a>
          <a href="https://kickbacks.ai">kickbacks.ai</a>
          <a href="https://github.com/jcentner/whipround">GitHub</a>
        </nav>
      </div>
      <span class="tagline">Crowdfunded tribute ads in the AI coding spinner.</span>
    </header>

    {
      (isPreview || !campaignChosen) && (
        <aside class="preview-notice">
          <strong>Preview.</strong>
          {!campaignChosen && (
            <Fragment>
              {" "}Campaign #1 hasn't been chosen yet, so the beneficiary copy
              below is placeholder text marked <code>[CAMPAIGN-TBD]</code>.
            </Fragment>
          )}
          {isPreview && (
            <Fragment>
              {" "}The goal and floor below are sized live from today's market
              and freeze at launch.
            </Fragment>
          )}
        </aside>
      )
    }

    {/* Revealed by the thermometer island when a pledger returns from Stripe (?pledged=1). */}
    <aside id="pledged-banner" class="pledged-banner" hidden>
      <strong>Thank you — your pledge is in.</strong>
      Watch the thermometer move, then tell one person who'd care.
    </aside>

    <h1>{campaign.headline}</h1>
    <p class="lede">{campaign.story}</p>

    <SpinnerMock adCopy={campaign.adCopy} />

    <section class="flow" aria-label="How it works">
      <ol class="flow-strip">
        <li>you pledge <strong>$5+</strong></li>
        <li>the pool buys <strong>slot #1</strong></li>
        <li>devs see it <strong>{breakdown.impressions.toLocaleString("en-US")}×</strong></li>
        <li>clicks land on <strong>the sponsor page</strong></li>
      </ol>
    </section>

    <Thermometer goalCents={campaign.goalCents} floorCents={breakdown.floorCents} />

    <p class="market-line">
      Right now, the top of the kickbacks.ai queue costs
      <strong id="mkt-price">—</strong> per 1,000 impressions.
      <span id="mkt-coverage" set:html={marketCoverageHtml(breakdown.goalCents)}></span>
    </p>

    <section class="buys" aria-labelledby="buys-heading">
      <h2 id="buys-heading">What your money buys</h2>
      <p>The goal is sized straight from the auction, in the open:</p>
      <dl
        class="ledger-math"
        id="ledger-math"
        data-target-blocks={breakdown.targetBlocks}
        data-buffer={breakdown.clickBufferMultiplier}
      >
        <div class="row">
          <dt>{breakdown.targetBlocks} blocks at #1</dt>
          <dd>{breakdown.impressions.toLocaleString("en-US")} impressions</dd>
        </div>
        <div class="row">
          <dt>Implied block price</dt>
          <dd id="ledger-implied">{formatUsd(breakdown.impliedBlockPriceCents)}</dd>
        </div>
        <div class="row">
          <dt>Click buffer</dt>
          <dd>{breakdown.clickBufferMultiplier}×</dd>
        </div>
        <div class="row">
          <dt>Floor — 1 block, tribute runs regardless</dt>
          <dd id="ledger-floor">{formatUsd(breakdown.floorCents)}</dd>
        </div>
        <div class="row total">
          <dt>Goal</dt>
          <dd id="ledger-goal">{formatUsd(breakdown.goalCents)}</dd>
        </div>
      </dl>
      <p class="fine">
        Until launch, the goal tracks the live market. At launch it freezes —
        any later re-size happens in public, never quietly.
      </p>
    </section>

    <section class="kicker" aria-labelledby="kicker-heading">
      <h2 id="kicker-heading">The best worst ad deal ever made</h2>
      <p>
        Clicks bill at <strong>50× the impression rate</strong>, and the ad
        links to {campaign.beneficiaryName}'s sponsor page. Every click drains
        the pool fast — and that's the point: the pool literally pays to send
        {" "}{campaign.beneficiaryName} potential sponsors. We want you to click.
      </p>
      <p class="drain-strip" aria-label="What one click does">
        <span class="drain-step">your click</span>
        <span class="drain-arrow" aria-hidden="true">─50×─►</span>
        <span class="drain-step">the pool pays</span>
        <span class="drain-arrow" aria-hidden="true">──►</span>
        <span class="drain-step good">a potential sponsor lands</span>
      </p>
      <p class="fine">Worth it, every time.</p>
    </section>

    <section class="pledge" aria-labelledby="pledge-heading">
      <h2 id="pledge-heading">Pledge</h2>
      {
        pledgeReady ? (
          <ul class="pledge-buttons">
            {campaign.pledgeLinks.map((link) => (
              <li>
                <a class={pledgeClass(link.amountCents)} href={link.url} rel="nofollow">
                  {pledgeLabel(link.amountCents)}
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="pledge-pending">Pledging opens when the campaign goes live.</p>
        )
      }
      <p class="pledge-note">
        <strong>
          Pledges are charged immediately and spent as promised: every dollar
          becomes spinner time or goes straight to {campaign.beneficiaryName}. If the
          pool can't cover even one block (<span id="note-floor">{formatUsd(breakdown.floorCents)}</span>) by {deadlineText},
          every pledge is refunded in full.
        </strong>
      </p>
    </section>

    <section class="faq" aria-labelledby="faq-heading">
      <h2 id="faq-heading">Questions</h2>

      <h3>Where does my money go?</h3>
      <p>
        Into a single ad buy on <a href="https://kickbacks.ai">kickbacks.ai</a> —
        the sponsored line that replaces the spinner verb in Claude Code and
        Codex. Pooled pledges bid for the #1 slot so the tribute serves first.
      </p>

      <h3>What if the goal isn't met?</h3>
      <p>
        We buy what the pool affords. The goal funds {breakdown.targetBlocks} blocks; if
        pledges only cover one or two by {deadlineText}, we buy those and the tribute
        runs anyway. Only if the pool can't cover a single block — under <span id="faq-floor">{formatUsd(breakdown.floorCents)}</span> —
        is everyone refunded in full. You're charged when you pledge; in that one
        case, the charge is reversed.
      </p>

      <h3>What happens to leftover funds?</h3>
      <p>
        Everything the ad buy doesn't spend — including everything raised past the
        goal — goes 100% to {campaign.beneficiaryName}'s sponsor/donate page. Whipround
        keeps $0.
      </p>

      <h3>Is this a charity?</h3>
      <p>
        No. A pledge buys participation in a community ad buy — it isn't a
        donation and isn't tax-deductible. It's a tribute, paid for in the open.
      </p>

      <h3>Why not just donate directly?</h3>
      <p>
        You should — {campaign.beneficiaryName}'s sponsor page takes money today, no
        crowdfund required. This buys the one thing a private donation can't:
        gratitude in public, inside the tools {campaign.beneficiaryName}'s work makes
        possible, in front of the exact people who owe them. A donation says thank
        you once. This says it {breakdown.impressions.toLocaleString("en-US")} times — and
        every click lands on the sponsor page, recruiting the recurring sponsors a
        one-off gift can't.
      </p>

      <h3>Who runs this?</h3>
      <p>
        Whipround is operated by
        <a href="https://write-it-right.ai">Write It Right</a> (write-it-right.ai) —
        that's the name you'll see on your card statement — and built by one
        person, <a href="https://x.com/JacobCentner">Jacob Centner</a>. Questions,
        complaints, compliments: he reads all three.
      </p>
    </section>

    <section class="suggest" aria-labelledby="suggest-heading">
      <h2 id="suggest-heading">Suggest the next campaign</h2>
      <p>
        Know someone the spinner should thank? Suggest a tribute. It's curated,
        not first-come — and please don't @-mention them yet; the blessing comes
        first.
      </p>
      <p>
        <a
          class="suggest-link"
          href="https://github.com/jcentner/whipround/issues/new?template=campaign-suggestion.yml"
          >Open a suggestion →</a
        >
      </p>
    </section>

    <footer>
      <p>
        Operated by <a href="https://write-it-right.ai">Write It Right</a> ·
        built by <a href="https://x.com/JacobCentner">@JacobCentner</a> ·
        follow <a href="https://x.com/whiprounddev">@whiprounddev</a> ·
        code on <a href="https://github.com/jcentner/whipround">GitHub</a>. Pledges
        are processed by Stripe; we store only aggregate totals, never your name
        or email.
      </p>
    </footer>
  </main>
</Layout>

<style>
  .brand {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-bottom: 2.25rem;
  }
  .brand-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
  }
  .wordmark {
    font-size: 0.8rem;
    letter-spacing: 0.35em;
    font-weight: 700;
    color: var(--muted);
  }
  .cursor {
    color: var(--accent);
    animation: cursor-blink 1.1s steps(1) infinite;
  }
  @keyframes cursor-blink {
    50% { opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }
  .site-links {
    display: flex;
    gap: 1rem;
    font-size: 0.85rem;
  }
  .site-links a {
    color: var(--muted);
    text-decoration: none;
  }
  .site-links a:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .tagline {
    font-size: 0.95rem;
    color: var(--muted);
  }

  main h2::before {
    content: "❯ " / "";
    color: var(--accent);
  }

  .flow {
    margin-top: 1.75rem;
  }
  .flow-strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .flow-strip li {
    white-space: nowrap;
  }
  .flow-strip li strong {
    color: var(--fg);
  }
  .flow-strip li + li::before {
    content: " ──► ";
    color: var(--accent);
    white-space: pre;
  }

  .drain-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.5rem;
    margin: 1rem 0 0.25rem;
    font-size: 0.9rem;
  }
  .drain-step {
    border: 1px dashed var(--border);
    border-radius: 0.4rem;
    padding: 0.25rem 0.6rem;
    white-space: nowrap;
  }
  .drain-step.good {
    border-color: var(--accent-2);
    color: var(--accent-2);
  }
  .drain-arrow {
    color: var(--accent);
    white-space: pre;
  }

  h1 {
    font-size: 2.3rem;
    margin: 0.5rem 0 1rem;
  }
  main > section {
    margin-top: 2.75rem;
  }

  .preview-notice {
    border: 1px dashed var(--muted);
    border-radius: 0.5rem;
    padding: 0.6rem 0.9rem;
    margin-bottom: 1.5rem;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .preview-notice code {
    color: var(--fg);
  }

  .pledged-banner {
    border: 1px solid var(--accent-2);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    background: color-mix(in srgb, var(--accent-2) 12%, transparent);
  }

  .lede {
    font-size: 1.15rem;
  }

  .market-line {
    color: var(--fg);
  }
  #mkt-price {
    color: var(--accent);
  }

  .ledger-math {
    margin: 0.75rem 0;
  }
  .ledger-math .row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px dashed var(--border);
  }
  .ledger-math dt {
    color: var(--muted);
  }
  .ledger-math dd {
    margin: 0;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .ledger-math .row.total {
    border-bottom: none;
    border-top: 1px solid var(--muted);
    margin-top: 0.25rem;
    padding-top: 0.6rem;
    font-weight: 700;
  }
  .ledger-math .row.total dt,
  .ledger-math .row.total dd {
    color: var(--fg);
  }
  .fine {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .pledge {
    margin: 2rem 0;
  }
  .pledge-buttons {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }
  .pledge-btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    border: 1px solid var(--accent);
    border-radius: 0.5rem;
    font-weight: 700;
    text-decoration: none;
  }
  .pledge-btn.primary {
    color: var(--bg);
    background: var(--accent);
    padding: 0.85rem 1.85rem;
    font-size: 1.05rem;
  }
  .pledge-btn.secondary {
    color: var(--accent);
    background: transparent;
    border-color: var(--accent);
  }
  .pledge-btn.ghost {
    color: var(--muted);
    background: transparent;
    border-color: var(--border);
    font-weight: 400;
  }
  .pledge-btn:hover {
    filter: brightness(1.08);
  }
  .pledge-btn.secondary:hover,
  .pledge-btn.ghost:hover {
    border-color: var(--accent);
    color: var(--accent);
    filter: none;
  }
  .pledge-pending {
    color: var(--muted);
    font-style: italic;
  }
  .pledge-note {
    font-size: 0.95rem;
  }

  .faq h3 {
    margin-bottom: 0.25rem;
  }
  .faq p {
    margin-top: 0;
  }

  .suggest-link {
    font-weight: 700;
  }

  footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
